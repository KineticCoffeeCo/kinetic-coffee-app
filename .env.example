# Stripe (Developers -> API keys in your Stripe dashboard)
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY
# Created after you run `stripe listen` locally, or from the Webhooks page once deployed
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET

# Supabase (Project Settings -> API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=REPLACE_WITH_YOUR_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_SUPABASE_ANON_KEY
# Project Settings -> API -> service_role key (KEEP SECRET, server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_YOUR_SUPABASE_SERVICE_ROLE_KEY

# Your live site URL (used for Stripe redirect links). Use http://localhost:3000 while developing.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
